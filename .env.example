# Copy to `.env` and fill in values. The CLI and web server load `.env` on startup.

# -----------------------------------------------------------------------------
# Required for all providers
# -----------------------------------------------------------------------------
MODEL_PROVIDER=gemini
# Options: gemini | openai

MODEL_NAME=gemini-2.5-flash
# Gemini: model id (e.g. gemini-2.5-flash)
# OpenAI cloud: model id (e.g. gpt-5.1-mini)
# OpenAI-compatible local (LM Studio, etc.): model id shown in the server UI

# -----------------------------------------------------------------------------
# Google Gemini (MODEL_PROVIDER=gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI API or OpenAI-compatible servers (MODEL_PROVIDER=openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Cloud: optional OPEN_AI_URL; defaults to https://api.openai.com/v1 if unset
# OPEN_AI_URL=https://api.openai.com/v1
#
# Local (LM Studio, vLLM, etc.): set OPEN_AI_URL to your server base including /v1.
# Uses POST {OPEN_AI_URL}/chat/completions
# MODEL_PROVIDER=openai
# MODEL_NAME=your-local-model-id
# OPEN_AI_URL=http://127.0.0.1:1234/v1
# Many local servers ignore the key; any non-empty value works:
# OPENAI_API_KEY=lm-studio
#
# MODEL_PROVIDER=lm_studio is still accepted as an alias for openai (deprecated).
