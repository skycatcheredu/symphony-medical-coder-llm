# Copy to `.env` and fill in values. The CLI and web server load `.env` on startup.

# -----------------------------------------------------------------------------
# Required for all providers
# -----------------------------------------------------------------------------
MODEL_PROVIDER=gemini
# Options: gemini | openai | lm_studio

MODEL_NAME=gemini-2.5-flash
# Gemini: model id (e.g. gemini-2.5-flash)
# OpenAI: model id (e.g. gpt-5.1-mini)
# LM Studio: id of the model loaded in LM Studio (see LM Studio UI)

# -----------------------------------------------------------------------------
# Google Gemini (MODEL_PROVIDER=gemini)
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# OpenAI cloud (MODEL_PROVIDER=openai)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
# Optional; defaults to https://api.openai.com/v1 if unset
# OPEN_AI_URL=https://api.openai.com/v1

# -----------------------------------------------------------------------------
# LM Studio or other OpenAI-compatible local server (MODEL_PROVIDER=lm_studio)
# Uses POST {OPEN_AI_URL}/chat/completions
# -----------------------------------------------------------------------------
# MODEL_PROVIDER=lm_studio
# MODEL_NAME=your-local-model-id
# OPEN_AI_URL=http://127.0.0.1:1234/v1
# Many local servers ignore the key; any non-empty value works:
# OPENAI_API_KEY=lm-studio
